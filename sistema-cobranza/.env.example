# Backend environment variables (Render/Railway)
DB_URL=jdbc:mysql://HOST:3306/alpay?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USER=YOUR_DB_USER
DB_PASS=YOUR_DB_PASSWORD
JWT_SECRET=BASE64_SECRET_MIN_32_BYTES
JWT_EXPIRATION_MS=86400000
CONTACT_TO=osmdigitalweb@gmail.com
CORS_ALLOWED_ORIGIN_PATTERNS=https://YOUR_FRONTEND_DOMAIN
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=YOUR_MAIL_USER
MAIL_PASS=YOUR_MAIL_PASS
MULTIPART_MAX_FILE_SIZE=10MB
MULTIPART_MAX_REQUEST_SIZE=20MB
